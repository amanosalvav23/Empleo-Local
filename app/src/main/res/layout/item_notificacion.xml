<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="notificacion"
            type="unc.edu.pe.empleolocal.data.model.Notificacion" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_notif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@{notificacion.leida ? 0xFFFFFFFF : 0xFFF0F7FF}"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@{notificacion.leida ? 0xFFE8EDF2 : 0xFF1F89E5}"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardBackgroundColor="#D1E3F5"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_notif_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:src="@drawable/ic_notifications"
                    app:tint="@color/login_blue_text" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_notif_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:text="@{notificacion.titulo}"
                android:textColor="@color/login_logo_text"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Título de Notificación"
                app:layout_constraintEnd_toStartOf="@id/iv_dot"
                app:layout_constraintStart_toEndOf="@id/cv_icon"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_notif_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@{notificacion.mensaje}"
                android:textColor="@color/login_subtitle"
                android:textSize="13sp"
                tools:text="Mensaje de la notificación aquí..."
                app:layout_constraintEnd_toEndOf="@id/tv_notif_title"
                app:layout_constraintStart_toStartOf="@id/tv_notif_title"
                app:layout_constraintTop_toBottomOf="@id/tv_notif_title" />

            <ImageView
                android:id="@+id/iv_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/bg_dot_blue"
                android:visibility="@{notificacion.leida ? 8 : 0}"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
