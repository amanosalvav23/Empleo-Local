<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="postulacion"
            type="unc.edu.pe.empleolocal.data.model.Postulacion" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screen_bg">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/btn_withdraw"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Company Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cv_logo"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/iv_company_logo"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                tools:src="@drawable/ic_briefcase" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_job_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{postulacion.tituloOferta}"
                                android:textColor="@color/login_logo_text"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="Título del Empleo" />

                            <TextView
                                android:id="@+id/tv_company_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{postulacion.empresaOferta}"
                                android:textColor="@color/login_subtitle"
                                android:textSize="14sp"
                                tools:text="Nombre de la Empresa" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/application_status_title"
                    android:textColor="@color/login_logo_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Timeline Vertical -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <!-- Step 1: Postulado -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/line_1"
                            android:layout_width="2dp"
                            android:layout_height="40dp"
                            android:layout_below="@id/dot_1"
                            android:layout_centerHorizontal="true"
                            android:layout_alignStart="@id/dot_1"
                            android:layout_alignEnd="@id/dot_1"
                            android:background="#E0E0E0" />

                        <ImageView
                            android:id="@+id/dot_1"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="#E0E0E0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/dot_1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_status_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Postulación Enviada"
                                android:textColor="@color/login_subtitle"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_desc_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tu CV ha sido recibido con éxito"
                                android:textColor="@color/login_subtitle"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Step 2: Revisión -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <View
                            android:id="@+id/line_2"
                            android:layout_width="2dp"
                            android:layout_height="40dp"
                            android:layout_below="@id/dot_2"
                            android:layout_alignStart="@id/dot_2"
                            android:layout_alignEnd="@id/dot_2"
                            android:background="#E0E0E0" />

                        <ImageView
                            android:id="@+id/dot_2"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="#E0E0E0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/dot_2"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_status_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="En Revisión"
                                android:textColor="@color/login_subtitle"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_desc_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="El equipo de RRHH está evaluando tu perfil"
                                android:textColor="@color/login_subtitle"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Step 3: Entrevista -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <View
                            android:id="@+id/line_3"
                            android:layout_width="2dp"
                            android:layout_height="40dp"
                            android:layout_below="@id/dot_3"
                            android:layout_alignStart="@id/dot_3"
                            android:layout_alignEnd="@id/dot_3"
                            android:background="#E0E0E0" />

                        <ImageView
                            android:id="@+id/dot_3"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="#E0E0E0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/dot_3"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_status_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Entrevista"
                                android:textColor="@color/login_subtitle"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_desc_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Has pasado a la etapa de entrevistas"
                                android:textColor="@color/login_subtitle"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Step 4: Finalizado -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <ImageView
                            android:id="@+id/dot_4"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="#E0E0E0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/dot_4"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_status_4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Proceso Finalizado"
                                android:textColor="@color/login_subtitle"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_desc_4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="El proceso de selección ha concluido"
                                android:textColor="@color/login_subtitle"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>

                <!-- Interview Info Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    app:cardBackgroundColor="#F7FAFC"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tv_status_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:text="Próximamente verás aquí los detalles de tu proceso de selección."
                        android:textColor="@color/login_subtitle"
                        android:textSize="14sp" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_withdraw"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="16dp"
            android:text="@string/btn_withdraw_application"
            android:textAllCaps="false"
            android:textColor="#F44336"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_withdraw"
            app:iconGravity="textStart"
            app:iconTint="#F44336"
            app:layout_constraintBottom_toBottomOf="parent"
            app:strokeColor="#F44336" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
