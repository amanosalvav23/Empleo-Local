<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screen_bg">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:elevation="0dp">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_sent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_sent"
                        app:chipBackgroundColor="#E3F2FD"
                        app:chipCornerRadius="20dp"
                        app:chipStrokeWidth="0dp"
                        app:icon="@drawable/ic_sent" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_review"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/filter_review"
                        app:chipBackgroundColor="#FFF3E0"
                        app:chipCornerRadius="20dp"
                        app:chipStrokeWidth="0dp"
                        app:icon="@drawable/ic_search_small" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_interview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/filter_interview"
                        app:chipBackgroundColor="#E8F5E9"
                        app:chipCornerRadius="20dp"
                        app:chipStrokeWidth="0dp"
                        app:icon="@drawable/ic_check_circle" />
                </LinearLayout>
            </HorizontalScrollView>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabs_postulaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tabIndicatorColor="@color/login_blue_text"
                app:tabSelectedTextColor="@color/login_blue_text"
                app:tabTextColor="@color/login_subtitle">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_all" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_active" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_archived" />
            </com.google.android.material.tabs.TabLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_postulaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:clipToPadding="false" />

                <TextView
                    android:id="@+id/tv_empty_postulaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="64dp"
                    android:gravity="center"
                    android:text="Aún no tienes postulaciones"
                    android:visibility="gone"
                    android:textColor="@color/login_subtitle" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
